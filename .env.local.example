AI_SMALL_REPO_MAX_SOURCE_CHARS=32000
AI_MEDIUM_REPO_MAX_FILES=60
AI_MEDIUM_REPO_MAX_SOURCE_CHARS=240000

# System Testing (optional per-user limits; hourly)
SYSTEM_TEST_RUNNER_MODE=auto
SYSTEM_TEST_RATE_LIMIT_PER_HOUR=5
SYSTEM_TEST_ADMIN_RATE_LIMIT_PER_HOUR=100
SYSTEM_TEST_DEV_RATE_LIMIT_PER_HOUR=100

